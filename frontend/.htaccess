# ==============================================================================
# Vol & Histoire — .htaccess pour URLs propres
# ==============================================================================
# À placer à la racine du dossier frontend/ (ou du DocumentRoot Apache)
# ==============================================================================

RewriteEngine On

# --------------------------------------------------------------------------
# 1. Forcer HTTPS (décommenter si SSL actif)
# --------------------------------------------------------------------------
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --------------------------------------------------------------------------
# 2. Rediriger www vers non-www (ou inversement, au choix)
# --------------------------------------------------------------------------
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# --------------------------------------------------------------------------
# 3. Proxy inverse vers le backend Node.js (API)
#    Toutes les requêtes /api/* sont redirigées vers Express
# --------------------------------------------------------------------------
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule ^api/(.*)$ http://localhost:3000/api/$1 [P,L]

# --------------------------------------------------------------------------
# 4. Ne pas réécrire les fichiers/dossiers qui existent réellement
#    (CSS, JS, images, vidéos, polices, etc.)
# --------------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# --------------------------------------------------------------------------
# 5. Redirection 301 : supprimer .html des URLs existantes
#    /hangar.html → /hangar  (SEO friendly)
# --------------------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/([^?\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# --------------------------------------------------------------------------
# 6. Réécriture interne : URLs propres vers fichiers .html
#    /hangar       → hangar.html
#    /details      → details.html
#    /a-propos     → a-propos.html
#    etc.
# --------------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# --------------------------------------------------------------------------
# 7. Page d'erreur 404 personnalisée
# --------------------------------------------------------------------------
ErrorDocument 404 /404.html

# --------------------------------------------------------------------------
# 8. Sécurité : empêcher l'accès aux fichiers sensibles
# --------------------------------------------------------------------------
<FilesMatch "\.(env|gitignore|sql|md|json|lock)$">
    Require all denied
</FilesMatch>

# Bloquer l'accès à .htaccess lui-même
<Files .htaccess>
    Require all denied
</Files>

# --------------------------------------------------------------------------
# 9. Cache navigateur pour les ressources statiques
# --------------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType video/mp4 "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

# --------------------------------------------------------------------------
# 10. Compression Gzip
# --------------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE application/json image/svg+xml
</IfModule>

# --------------------------------------------------------------------------
# 11. En-têtes de sécurité supplémentaires
# --------------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
