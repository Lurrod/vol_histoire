{
  "testEnvironment": "node",
  "testMatch": ["**/__tests__/**/*.test.js"],
  "collectCoverageFrom": [
    "validators.js",
    "app.js",
    "middleware/**/*.js",
    "routes/**/*.js"
  ],
  "coverageReporters": ["text", "lcov"],
  "coverageThreshold": {
    "global": {
      "statements": 80,
      "branches": 80,
      "functions": 80,
      "lines": 80
    }
  },
  "verbose": true,
  "resolver": "./jest-resolver.js"
}
