# Base de données PostgreSQL
DB_USER=
DB_HOST=localhost
DB_NAME=vol_histoire
DB_PASSWORD=
DB_PORT=5432
DB_SSL=false

# JWT (générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=
REFRESH_SECRET=

# Email SMTP
MAIL_USER=
MAIL_PASS=

# Frontend
FRONTEND_URL=http://localhost:8080

# Serveur
PORT=3000
ALLOWED_ORIGINS=http://localhost:8080

# Logging (error, warn, info, debug)
LOG_LEVEL=info

# Redis (optionnel) — active le rate-limit et le cache applicatif partagés entre instances
# Sans REDIS_URL : fallback mémoire (OK pour instance unique / dev)
# REDIS_URL=redis://localhost:6379

# Monitoring (Prometheus /api/metrics, /api/status) — token obligatoire en production
# METRICS_TOKEN=
